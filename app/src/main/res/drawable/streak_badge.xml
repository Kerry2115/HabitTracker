<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="#FFB000" />
        </shape>
    </item>
    <item android:left="4dp" android:top="4dp" android:right="4dp" android:bottom="4dp">
        <shape android:shape="oval">
            <gradient
                android:startColor="#FF6A00"
                android:centerColor="#FF3D00"
                android:endColor="#FFD54F"
                android:angle="45" />
            <stroke
                android:width="2dp"
                android:color="#FFFDE7" />
        </shape>
    </item>
</layer-list>
